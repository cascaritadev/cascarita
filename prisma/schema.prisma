// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ── NextAuth Models ─────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?   // null for OAuth users (Google)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
  orders   Order[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ── Órdenes ──────────────────────────────────────────────────────────────────

model Order {
  id              String      @id @default(cuid())
  userId          String?
  email           String

  // Stripe
  stripeSessionId String      @unique
  stripePaymentId String?

  // Estado
  status          OrderStatus @default(PENDING)

  // Producto (Mystery Box)
  boxType         String      // debutante | doble | hat-trick | jersey-club
  categoria       String
  talla           String
  exclusiones     String[]    // lista de equipos excluidos

  // Precio (en centavos MXN)
  amountTotal     Int
  currency        String      @default("mxn")

  // Dirección de envío (recopilada por Stripe Checkout)
  shippingName    String?
  shippingPhone   String?
  shippingLine1   String?
  shippingLine2   String?
  shippingCity    String?
  shippingState   String?
  shippingZip     String?
  shippingCountry String?

  // SkyDropX
  skydropxShipmentId String?
  trackingNumber     String?
  trackingUrl        String?
  carrier            String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id])
}

enum OrderStatus {
  PENDING      // esperando pago
  PAID         // pago confirmado por Stripe
  PROCESSING   // preparando envío
  SHIPPED      // enviado (SkyDropX creado)
  DELIVERED    // entregado
  CANCELLED    // cancelado
}
